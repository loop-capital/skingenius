  {
    "id": "barrier_disruption",
    "name": "Skin Barrier Disruption",
    "pathway_type": "structural",
    "description": "Impaired stratum corneum integrity due to ceramide depletion, tight junction dysfunction, reduced filaggrin/involucrin/loricrin, and altered lipid lamellae. Results in increased transepidermal water loss (TEWL), allergen penetration, and inflammation. Central to eczema, xerosis, and steroid-induced atrophy.",
    "key_components": [
      "Ceramides (40-50% of barrier lipids)",
      "Cholesterol (25%)",
      "Free fatty acids (10-15%)",
      "Filaggrin (natural moisturizing factor precursor)",
      "Loricrin and involucrin (cornified envelope)",
      "Tight junctions (claudin-1, occludin, ZO-1)"
    ],
    "causes": [
      "Genetic (filaggrin mutations - atopic dermatitis)",
      "Cortisol excess",
      "UV damage",
      "Harsh surfactants (SLS)",
      "Aging (reduced lipid synthesis)",
      "Topical corticosteroids (chronic use)",
      "Nutrient deficiencies (zinc, essential fatty acids)"
    ],
    "consequences": [
      "Increased TEWL",
      "Dryness and scaling",
      "Allergen/irritant penetration",
      "Inflammation (itch-scratch cycle)",
      "Infection susceptibility"
    ],
    "evidence_level": "A",
    "source_citations": [
      "hormone-skin-connection.md: Section 1.1 (cortisol → barrier)",
      "clinical-guidelines.md: AD section (barrier repair foundation)"
    ]
  },
