      "Inflammatory cytokines (TNF-α, IL-1)",
      "AGEs via RAGE",
      "Smoking"
    ],
    "inhibitors": [
      "TGF-β1 (stimulates collagen synthesis)",
      "TIMP-1, TIMP-3 (tissue inhibitors of MMPs)",
      "Estrogen (downregulates MMP-1 via AP-1 suppression)",
      "Retinoids (increase collagen synthesis, reduce MMPs)",
      "Vitamin C (cofactor for collagen synthesis)"
    ],
    "skin_effects": [
      "Wrinkle formation",
      "Skin laxity",
      "Photoaging",
      "Delayed wound healing",
      "Skin thinning"
