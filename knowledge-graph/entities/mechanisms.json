    "id": "glycation_pathway",
    "name": "Glycation / AGE Formation",
    "pathway_type": "metabolic",
    "description": "Non-enzymatic attachment of reducing sugars to amino groups on proteins (lysine, arginine) forming Schiff bases → Amadori products → advanced glycation end-products (AGEs). Cross-links collagen and elastin → stiffness, yellowing, reduced elasticity. RAGE signaling amplifies inflammation.",
    "key_mediators": [
      "Glucose (primary sugar)",
      "Fructose (more reactive than glucose)",
      "Methylglyoxal (reactive dicarbonyl)",
      "RAGE (receptor for AGEs)",
      "NF-κB (downstream of RAGE)"
    ],
    "target_proteins": [
      "Collagen (types I and III)",
      "Elastin",
      "Fibronectin",
      "Crystallin (lens)"
    ],
    "accelerating_factors": [
      "Hyperglycemia / insulin resistance",
      "High dietary AGEs (grilled, fried foods)",
      "Aging",
      "UV exposure",
      "Smoking (generates glycotoxins)"
    ],
    "skin_effects": [
      "Collagen cross-linking and stiffness",
      "Reduced elasticity (30-50% in advanced glycation)",
      "Yellowing of skin",
      "Wrinkle formation",
      "Impaired wound healing"
    ],
    "evidence_level": "B",
    "source_citations": [
      "hormone-skin-connection.md: Section 1.5 (glycation)"
    ]
